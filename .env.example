# ============================================================
# Awaken Bio Labs — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in all values.
# NEVER commit .env or .env.local to version control.
#
# In production, set these in Vercel:
#   Project → Settings → Environment Variables
# ============================================================


# ------------------------------------------------------------
# Site
# ------------------------------------------------------------

# Public URL of the deployed site (no trailing slash).
# Used to build links in emails and contract signing URLs.
# Safe to expose to the browser — prefix NEXT_PUBLIC_ is intentional.
NEXT_PUBLIC_SITE_URL=https://awakenbiolabs.com


# ------------------------------------------------------------
# Admin
# ------------------------------------------------------------

# Password used to log in to /admin.
# Generate with: openssl rand -base64 32
ADMIN_PASSWORD=

# Session token issued after a successful admin login.
# Generate with: openssl rand -hex 32
ADMIN_SESSION_TOKEN=


# ------------------------------------------------------------
# Email — Resend
# (https://resend.com → API Keys)
# ------------------------------------------------------------

# Resend secret API key (starts with "re_").
RESEND_API_KEY=

# Verified sender address configured in Resend.
# Must match a domain you've added and verified in Resend.
EMAIL_FROM=orders@awakenbiolabs.com

# Admin inbox that receives order notifications and contact form emails.
EMAIL_TO=admin@awakenbiolabs.com


# ------------------------------------------------------------
# Payments — Quiklie
# (Quiklie merchant dashboard → API Settings)
# ------------------------------------------------------------

# Quiklie secret API key.
QUIKLIE_API_KEY=

# Quiklie merchant / account ID.
QUIKLIE_MERCHANT_ID=


# ------------------------------------------------------------
# Shipping — ShipStation
# (ShipStation → Account → API Settings)
# ------------------------------------------------------------

# ShipStation API key.
SHIPSTATION_API_KEY=

# ShipStation API secret.
SHIPSTATION_API_SECRET=

# Secret appended to the ShipStation webhook URL as ?secret=
# so incoming webhooks can be authenticated.
# Generate with: openssl rand -hex 32
# Set this same value in ShipStation → Integrations → Webhooks → URL
SHIPSTATION_WEBHOOK_SECRET=


# ------------------------------------------------------------
# Database — Vercel KV (Upstash Redis)
# (Vercel dashboard → Storage → your KV store → .env.local tab)
# ------------------------------------------------------------

# KV REST API endpoint URL (provided by Vercel/Upstash).
KV_REST_API_URL=

# KV REST API token (provided by Vercel/Upstash).
KV_REST_API_TOKEN=

# Read-only token — used for safe read operations (optional but recommended).
KV_REST_API_READ_ONLY_TOKEN=


# ------------------------------------------------------------
# Scheduled jobs
# (used by Vercel Cron to authenticate /api/health calls)
# ------------------------------------------------------------

# Secret sent in the Authorization header by Vercel Cron.
# Generate with: openssl rand -hex 32
CRON_SECRET=
